# Frontend Environment Variables (Vite)
# Copy this file to .env and fill in your values

# Stripe publishable key (public, safe for frontend)
VITE_STRIPE_PUBLIC_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY

# Stripe Checkout Lambda Function URL (set automatically by Amplify deploy)
VITE_STRIPE_CHECKOUT_URL=https://YOUR_FUNCTION_URL.lambda-url.eu-north-1.on.aws/

# OTP Sender Lambda Function URL (from CloudFormation output: OtpSenderUrl)
VITE_OTP_SENDER_URL=https://YOUR_FUNCTION_URL.lambda-url.eu-north-1.on.aws/

# -------------------------------------------------------------------
# Backend Secrets (configured via `npx ampx sandbox secret set`)
# These are NOT in .env - they are stored in AWS SSM Parameter Store
# -------------------------------------------------------------------
# STRIPE_SECRET_KEY              - Stripe secret key for subscription billing
# TWILIO_ACCOUNT_SID             - Twilio account SID for WhatsApp/SMS
# TWILIO_AUTH_TOKEN              - Twilio auth token
# TWILIO_CHATWORKS_WHATSAPP_AUTH_CONTENT_SID - Twilio content SID for OTP messages
# TWILIO_REMINDER_CONTENT_SID   - Twilio content SID for daily reminders
# WHATSAPP_VERIFY_TOKEN          - Webhook verification token for WhatsApp
